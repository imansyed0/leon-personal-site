{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["dist/**", "data/**", "views/**"],
        "excludeFiles": ["**/*.map"]
      }
    },
    {
      "src": "package.json",
      "use": "@vercel/node",
      "config": {
        "buildCommand": "npm run vercel-build",
        "outputDirectory": "dist"
      }
    },
    {
      "src": "timemap/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build",
        "devCommand": "cross-env PORT=$PORT npm --prefix timemap run dev",
        "includeBuildOutput": false
      }
    }
  ],
  "routes": [
    {
      "src": "/guapinol/(api|images)/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "^/(api|images)/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/guapinol/?$",
      "dest": "/timemap/"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/guapinol/(.*)",
      "dest": "/timemap/$1"
    }
  ]
} 