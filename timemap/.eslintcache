/time/Axis.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/atoms/Content.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/atoms/Controls.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/time/atoms/Header.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/time/atoms/Clip.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/common/constants.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/space/carto/Map.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/reducers/app.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/reducers/root.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/reducers/ui.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/reducers/domain.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/reducers/features.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/store/plugins/urlState/applyUrlState.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/store/plugins/urlState/middleware.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/time/atoms/DatetimeBar.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/time/atoms/DatetimeSquare.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/time/atoms/DatetimePentagon.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/time/atoms/DatetimeStar.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/time/atoms/DatetimeTriangle.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/store/initial.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/atoms/ColoredMarkers.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/time/atoms/Project.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/selectors/helpers.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/reducers/validate/validators.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/atoms/SitesIcon.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/controls/atoms/PanelTree.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/atoms/CoverIcon.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/atoms/Checkbox.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/atoms/InfoIcon.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/controls/atoms/Text.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/controls/atoms/Time.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/controls/atoms/Caret.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/controls/atoms/Button.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/controls/atoms/CustomField.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/controls/atoms/Media.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/atoms/NoSource.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/atoms/Md.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/atoms/Spinner.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/space/carto/atoms/Regions.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/space/carto/atoms/Sites.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/space/carto/atoms/Events.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/space/carto/atoms/SelectedEvents.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/space/carto/atoms/SatelliteOverlayToggle.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/space/carto/atoms/Narratives.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/space/carto/atoms/DefsMarkers.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/store/plugins/urlState/urlState.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/store/plugins/urlState/schema.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/reducers/validate/eventSchema.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/reducers/validate/regionSchema.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/reducers/validate/associationsSchema.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/reducers/validate/sourceSchema.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/reducers/validate/shapeSchema.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/reducers/validate/siteSchema.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/controls/atoms/TelegramEmbed.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/IntroPopup.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/common/utilities/video.js",[],"/Users/imans/Documents/datasheet-server/timemap/src/components/time/atoms/YearPicker.js",["390","391"],"import React, { useState, useEffect } from \"react\";\n\nconst YearPicker = ({ events, dims, onYearSelect, onShowFullRange, currentYear }) => {\n  const [selectedYear, setSelectedYear] = useState(currentYear);\n  const [isInternalUpdate, setIsInternalUpdate] = useState(false);\n  const [isFullRange, setIsFullRange] = useState(currentYear === null);\n  \n  // Generate years from event data\n  const getYearRange = () => {\n    if (!events || events.length === 0) {\n      return [];\n    }\n    \n    const validDates = events\n      .filter(event => event.datetime instanceof Date && !isNaN(event.datetime))\n      .map(event => event.datetime.getFullYear());\n    \n    if (validDates.length === 0) {\n      return [];\n    }\n    \n    const minYear = Math.min(...validDates);\n    const maxYear = Math.max(...validDates);\n    \n    const years = [];\n    for (let year = minYear; year <= maxYear; year++) {\n      years.push(year);\n    }\n    \n    return years;\n  };\n\n  const years = getYearRange();\n  const itemHeight = 15; // Height of each year item\n  const visibleItems = 5; // Number of visible items\n  const centerIndex = Math.floor(visibleItems / 2); // Index of center item (2)\n  \n  // Initialize selected year only when currentYear changes externally\n  useEffect(() => {\n    if (isInternalUpdate) {\n      setIsInternalUpdate(false);\n      return;\n    }\n    \n    if (currentYear === null) {\n      // Full range state\n      setIsFullRange(true);\n      setSelectedYear(null);\n    } else if (currentYear && years.includes(currentYear)) {\n      setIsFullRange(false);\n      setSelectedYear(currentYear);\n    } else if (years.length > 0 && !selectedYear && currentYear !== null) {\n      const middleYear = years[Math.floor(years.length / 2)];\n      setIsFullRange(false);\n      setSelectedYear(middleYear);\n    }\n  }, [currentYear, years.length]);\n\n  // Handle year selection\n  const handleYearClick = (year) => {\n    setIsInternalUpdate(true);\n    setIsFullRange(false);\n    setSelectedYear(year);\n    onYearSelect(year);\n  };\n\n  // Handle full range selection\n  const handleFullRangeClick = () => {\n    setIsInternalUpdate(true);\n    setIsFullRange(true);\n    setSelectedYear(null);\n    onShowFullRange();\n  };\n\n  // Handle scroll wheel events\n  const handleWheel = (event) => {\n    event.preventDefault();\n    \n    if (isFullRange) {\n      // If in full range, scroll down goes to first year\n      const delta = event.deltaY > 0 ? 1 : -1;\n      if (delta > 0 && years.length > 0) {\n        // Scroll down - go to first year\n        setIsInternalUpdate(true);\n        setIsFullRange(false);\n        setSelectedYear(years[0]);\n        onYearSelect(years[0]);\n      }\n      return;\n    }\n    \n    const delta = event.deltaY > 0 ? 1 : -1;\n    const currentIndex = years.indexOf(selectedYear);\n    \n    if (delta < 0 && currentIndex === 0) {\n      // Scroll up from first year - go to full range\n      setIsInternalUpdate(true);\n      setIsFullRange(true);\n      setSelectedYear(null);\n      onShowFullRange();\n      return;\n    }\n    \n    const newIndex = Math.max(0, Math.min(years.length - 1, currentIndex + delta));\n    \n    if (newIndex !== currentIndex && years[newIndex]) {\n      setIsInternalUpdate(true);\n      setSelectedYear(years[newIndex]);\n      onYearSelect(years[newIndex]);\n    }\n  };\n\n  // Handle arrow navigation\n  const handleArrowClick = (direction) => {\n    if (isFullRange) {\n      // If in full range and going down, go to first year\n      if (direction === 'down' && years.length > 0) {\n        setIsInternalUpdate(true);\n        setIsFullRange(false);\n        setSelectedYear(years[0]);\n        onYearSelect(years[0]);\n      }\n      return;\n    }\n    \n    const currentIndex = years.indexOf(selectedYear);\n    \n    if (direction === 'up' && currentIndex === 0) {\n      // If at first year and going up, go to full range\n      setIsInternalUpdate(true);\n      setIsFullRange(true);\n      setSelectedYear(null);\n      onShowFullRange();\n      return;\n    }\n    \n    const newIndex = direction === 'up' \n      ? Math.max(0, currentIndex - 1)\n      : Math.min(years.length - 1, currentIndex + 1);\n    \n    if (newIndex !== currentIndex && years[newIndex]) {\n      setIsInternalUpdate(true);\n      setSelectedYear(years[newIndex]);\n      onYearSelect(years[newIndex]);\n    }\n  };\n\n  if (years.length === 0) {\n    return null;\n  }\n\n  // Calculate which years to show\n  let visibleYears = [];\n  let adjustedStartIndex = 0;\n  \n  if (isFullRange) {\n    // In full range mode, show first few years after \"All\"\n    visibleYears = years.slice(0, Math.min(visibleItems - 1, years.length));\n    adjustedStartIndex = 0;\n  } else {\n    // In year mode, calculate normally but always leave room for \"All\" at top\n    const selectedIndex = years.indexOf(selectedYear);\n    const startIndex = Math.max(0, selectedIndex - centerIndex + 1); // +1 to leave room for \"All\"\n    const endIndex = Math.min(years.length, startIndex + visibleItems - 1); // -1 for \"All\"\n    \n    adjustedStartIndex = Math.max(0, Math.min(startIndex, years.length - visibleItems + 1));\n    const adjustedEndIndex = Math.min(years.length, adjustedStartIndex + visibleItems - 1);\n    \n    visibleYears = years.slice(adjustedStartIndex, adjustedEndIndex);\n  }\n  \n  // Position for the year picker\n  const xPosition = dims.width - dims.width_controls + 40;\n  const yPosition = 20;\n\n  return (\n    <g \n      transform={`translate(${xPosition}, ${yPosition})`}\n      onWheel={handleWheel}\n      style={{ cursor: 'pointer' }}\n    >\n      {/* Background for scroll area */}\n      <rect\n        x=\"-25\"\n        y=\"0\"\n        width=\"50\"\n        height={visibleItems * itemHeight}\n        fill=\"transparent\"\n        stroke=\"none\"\n      />\n      \n      {/* Always render \"All Years\" option at the top */}\n      <g key=\"all-years\">\n        {isFullRange && (\n          <rect\n            x=\"-20\"\n            y=\"2\"\n            width=\"40\"\n            height={itemHeight - 2}\n            fill=\"rgba(255, 255, 255, 0.1)\"\n            rx=\"3\"\n            ry=\"3\"\n          />\n        )}\n        <text\n          className=\"year-picker-item\"\n          x=\"0\"\n          y={itemHeight/2 + 4}\n          textAnchor=\"middle\"\n          fontSize={isFullRange ? \"12px\" : \"10px\"}\n          fontWeight={isFullRange ? \"bold\" : \"normal\"}\n          fill=\"#ffffff\"\n          opacity={isFullRange ? 1 : 0.4}\n          style={{\n            cursor: 'pointer',\n            transition: 'all 0.2s ease',\n            letterSpacing: '0.05em'\n          }}\n          onClick={handleFullRangeClick}\n        >\n          All\n        </text>\n      </g>\n      \n      {/* Render visible years, starting from position 1 */}\n      {visibleYears.map((year, index) => {\n        const actualIndex = index + 1; // Always offset by 1 to make room for \"All\"\n        const isCenter = !isFullRange && year === selectedYear;\n        const selectedIndex = years.indexOf(selectedYear);\n        const distanceFromCenter = isFullRange ? \n          1 : Math.abs(adjustedStartIndex + index - selectedIndex);\n        \n        let fontSize = \"10px\";\n        let opacity = 0.4;\n        let fontWeight = \"normal\";\n        \n        if (isCenter) {\n          fontSize = \"12px\";\n          opacity = 1;\n          fontWeight = \"bold\";\n        } else if (!isFullRange && distanceFromCenter === 1) {\n          fontSize = \"11px\";\n          opacity = 0.7;\n          fontWeight = \"normal\";\n        } else if (!isFullRange && distanceFromCenter === 2) {\n          fontSize = \"10px\";\n          opacity = 0.5;\n          fontWeight = \"normal\";\n        }\n\n        return (\n          <g key={year}>\n            {/* Background highlight for center year */}\n            {isCenter && (\n              <rect\n                x=\"-20\"\n                y={actualIndex * itemHeight + 2}\n                width=\"40\"\n                height={itemHeight - 2}\n                fill=\"rgba(255, 255, 255, 0.1)\"\n                rx=\"3\"\n                ry=\"3\"\n              />\n            )}\n            \n            {/* Year text */}\n            <text\n              className=\"year-picker-item\"\n              x=\"0\"\n              y={actualIndex * itemHeight + itemHeight/2 + 4}\n              textAnchor=\"middle\"\n              fontSize={fontSize}\n              fontWeight={fontWeight}\n              fill=\"#ffffff\"\n              opacity={opacity}\n              style={{\n                cursor: 'pointer',\n                transition: 'all 0.2s ease',\n                letterSpacing: '0.05em'\n              }}\n              onClick={() => handleYearClick(year)}\n            >\n              {year}\n            </text>\n          </g>\n        );\n      })}\n      \n      {/* Scroll indicators */}\n      {(!isFullRange && years.indexOf(selectedYear) > 0) && (\n        <text\n          x=\"0\"\n          y=\"-5\"\n          textAnchor=\"middle\"\n          fontSize=\"8px\"\n          fill=\"#666666\"\n          style={{ cursor: 'pointer' }}\n          onClick={() => handleArrowClick('up')}\n        >\n          ↑\n        </text>\n      )}\n      \n      {(!isFullRange && years.indexOf(selectedYear) < years.length - 1) && (\n        <text\n          x=\"0\"\n          y={visibleItems * itemHeight + 15}\n          textAnchor=\"middle\"\n          fontSize=\"8px\"\n          fill=\"#666666\"\n          style={{ cursor: 'pointer' }}\n          onClick={() => handleArrowClick('down')}\n        >\n          ↓\n        </text>\n      )}\n      \n      {/* Show down arrow when in full range (can navigate to years) */}\n      {isFullRange && years.length > 0 && (\n        <text\n          x=\"0\"\n          y={visibleItems * itemHeight + 15}\n          textAnchor=\"middle\"\n          fontSize=\"8px\"\n          fill=\"#666666\"\n          style={{ cursor: 'pointer' }}\n          onClick={() => handleArrowClick('down')}\n        >\n          ↓\n        </text>\n      )}\n    </g>\n  );\n};\n\nexport default YearPicker; ",{"ruleId":"392","replacedBy":"393"},{"ruleId":"394","replacedBy":"395"},{"ruleId":"396","severity":1,"message":"397","line":57,"column":6,"nodeType":"398","endLine":57,"endColumn":33,"suggestions":"399"},{"ruleId":"400","severity":1,"message":"401","line":164,"column":11,"nodeType":"402","messageId":"403","endLine":164,"endColumn":19},"no-native-reassign",["404"],"no-negated-in-lhs",["405"],"react-hooks/exhaustive-deps","React Hook useEffect has missing dependencies: 'isInternalUpdate', 'selectedYear', and 'years'. Either include them or remove the dependency array.","ArrayExpression",["406"],"no-unused-vars","'endIndex' is assigned a value but never used.","Identifier","unusedVar","no-global-assign","no-unsafe-negation",{"desc":"407","fix":"408"},"Update the dependencies array to be: [currentYear, isInternalUpdate, selectedYear, years, years.length]",{"range":"409","text":"410"},[1799,1826],"[currentYear, isInternalUpdate, selectedYear, years, years.length]"]